{
  "version": "0.0.1",
  "name": "bun-playground",
  "private": true,
  "engines": {
    "bun": "^1.3.0"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist",
    "start": "bun run dist/index.js",
    "dev": "bun src/index.ts",
    "dev:watch": "bun --watch src/index.ts",
    "dev:debug": "bun --watch --inspect-wait=0.0.0.0:9229/debug src/index.ts"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@types/bun": "^1.3.0"
  }
}
